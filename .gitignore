# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/

# Logs and temp
*.log
*.tmp
/tmp/

# Test artifacts
tests/.tmp/
__pycache__/
.pytest_cache/
test-results/

# SQLite write-ahead / shared-memory sidecars
*-wal
*-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Managed databases created at runtime (keep the bundled sample + .htaccess)
src/databases/*
!src/databases/.htaccess
!src/databases/sample.sqlite

# Loadable SQLite extension binaries dropped into src/ext/
src/ext/*
!src/ext/.gitkeep


src/config.local.json
